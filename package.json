{
  "name": "faketect",
  "version": "2.0.1",
  "private": true,
  "description": "Détecteur d'images IA multi-plateforme avec analyse de documents - FakeTect",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=packages/web",
    "test": "npm run test --workspaces",
    "test:web": "npm run test --workspace=packages/web",
    "test:api": "npm run test --workspace=packages/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "npm run test:coverage --workspaces",
    "seo:generate": "npm run seo:generate --workspace=packages/web"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "concurrently": "^8.2.2",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "YACINE",
  "license": "MIT"
}

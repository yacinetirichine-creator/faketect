# ===========================================
# FAKETECT API v2.0 - Configuration
# FakeTect
# ===========================================

PORT=3001
NODE_ENV=development

# Optionnel (dev uniquement) : bypass auth si Supabase non configuré.
# NE PAS activer en production.
DEV_AUTH_BYPASS=false

# ===========================================
# SUPABASE
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================
# APIs de Détection
# ===========================================
SIGHTENGINE_USER=your_api_user
SIGHTENGINE_SECRET=your_api_secret
ILLUMINARTY_API_KEY=your_api_key

# ===========================================
# Limites
# ===========================================
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE=20971520
MAX_BATCH_SIZE=20

# Documents
MAX_PDF_PAGES=20
PDF_RENDER_SCALE=2

# Détection
AI_DECISION_THRESHOLD=0.7
GUEST_DAILY_LIMIT=3

# ===========================================
# Video (frames) - nécessite ffmpeg installé
# ===========================================
# Quota journalier par utilisateur (auth requis) pour l'endpoint /api/analyze/video
VIDEO_DAILY_LIMIT=15
# Analyse uniquement les 60 premières secondes (par défaut).
VIDEO_MAX_SECONDS=60
# Limite de taille upload vidéo (octets)
VIDEO_MAX_BYTES=209715200
# Sampling "coarse" (ex: 0.5 = 1 frame / 2s)
VIDEO_COARSE_FPS=0.5
# Sampling "burst" autour des timestamps suspects
VIDEO_BURST_FPS=2
VIDEO_BURST_WINDOW_SECONDS=4
# Sécurité/coût: plafond de frames analysées par requête
VIDEO_MAX_FRAMES=80
# Nombre de timestamps suspects à raffiner
VIDEO_BURST_TOP_K=3

# ===========================================
# Certification / Traçabilité (HMAC)
# ===========================================
# Permet de signer les certificats liés aux rapports PDF.
# Requis pour une signature "vérifiable".
CERT_SIGNING_SECRET=change-me-super-secret
# Optionnel: pour rotation de clé (vérifie aussi avec l'ancienne)
CERT_SIGNING_SECRET_OLD=

# ===========================================
# Monitoring & Métriques
# ===========================================
# Token pour accéder à /api/metrics (optionnel, si non défini = endpoint public)
ADMIN_METRICS_TOKEN=your-secret-metrics-token

# ===========================================
# CORS
# ===========================================
ALLOWED_ORIGINS=https://faketect.com,https://www.faketect.com,https://faketect.app,https://www.faketect.app,https://faketect.vercel.app,http://localhost:5173,http://localhost:3000

# ===========================================
# Sécurité Juridique (CRITIQUE)
# ===========================================
# Secret pour signature certificats (minimum 32 caractères)
# Générer avec: openssl rand -hex 32
# EXEMPLE (NE PAS UTILISER EN PRODUCTION):
CERT_SIGNING_SECRET=994ac7f663f60f36ccf650aef990467577bebd3777940faf69d335f2acc7a4e0

# ===========================================
# Emails Professionnels
# ===========================================
COMPANY_EMAIL=contact@faketect.com
DPO_EMAIL=dpo@faketect.com
LEGAL_EMAIL=legal@faketect.com
SUPPORT_EMAIL=support@faketect.com
COMPLAINTS_EMAIL=complaints@faketect.com
REVIEW_EMAIL=review@faketect.com
COMPANY_PHONE=+33123456789

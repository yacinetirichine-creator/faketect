# =============================================================================
# CONFIGURATION JURIDIQUE FAKETECT
# =============================================================================
# Copiez ce fichier vers packages/api/.env et complétez les valeurs
# =============================================================================

# -----------------------------------------------------------------------------
# INFORMATIONS ENTREPRISE (À COMPLÉTER DEPUIS VOTRE KBIS)
# -----------------------------------------------------------------------------

# Nom de l'entreprise
COMPANY_NAME=JARVIS

# Forme juridique (SARL, SAS, SA, EI, EURL, etc.)
COMPANY_LEGAL_FORM=

# SIRET (14 chiffres)
COMPANY_SIRET=

# SIREN (9 chiffres)
COMPANY_SIREN=

# RCS (ex: "Paris B 123456789")
COMPANY_RCS=

# Code APE/NAF
COMPANY_APE=

# Capital social (en euros, ex: 10000)
COMPANY_CAPITAL=

# Numéro TVA intracommunautaire (ex: FR12345678900)
COMPANY_TVA=

# Adresse complète du siège social
COMPANY_ADDRESS=

# Code postal
COMPANY_POSTAL_CODE=

# Ville
COMPANY_CITY=

# Pays
COMPANY_COUNTRY=France

# Date d'immatriculation (YYYY-MM-DD)
COMPANY_REGISTRATION_DATE=

# Nom du dirigeant principal
COMPANY_DIRECTOR_NAME=

# Fonction du dirigeant (Président, Gérant, etc.)
COMPANY_DIRECTOR_TITLE=

# -----------------------------------------------------------------------------
# CONTACTS PROFESSIONNELS (À CRÉER)
# -----------------------------------------------------------------------------

# Email principal
CONTACT_EMAIL=contact@faketect.com

# Email juridique
LEGAL_EMAIL=legal@faketect.com

# Email DPO (Délégué à la Protection des Données) - OBLIGATOIRE RGPD
DPO_EMAIL=dpo@faketect.com

# Email support technique
SUPPORT_EMAIL=support@faketect.com

# Email commandes
ORDERS_EMAIL=orders@faketect.com

# Email réclamations
COMPLAINTS_EMAIL=complaints@faketect.com

# Email remboursements/rétractation
REFUNDS_EMAIL=refunds@faketect.com

# Email résiliations
CANCEL_EMAIL=cancel@faketect.com

# Téléphone entreprise (format international recommandé: +33...)
COMPANY_PHONE=

# -----------------------------------------------------------------------------
# ASSURANCE RC PROFESSIONNELLE (RECOMMANDÉE)
# -----------------------------------------------------------------------------

# Nom de l'assureur
INSURANCE_COMPANY=

# Numéro de police d'assurance
INSURANCE_POLICY_NUMBER=

# Date d'expiration (YYYY-MM-DD)
INSURANCE_EXPIRY_DATE=

# -----------------------------------------------------------------------------
# MÉDIATEUR DE LA CONSOMMATION (OBLIGATOIRE SI B2C)
# -----------------------------------------------------------------------------
# Liste officielle: https://www.economie.gouv.fr/mediation-conso/mediateurs-references

# Nom du médiateur
MEDIATOR_NAME=

# Adresse du médiateur
MEDIATOR_ADDRESS=

# Site web du médiateur
MEDIATOR_WEBSITE=

# Email du médiateur
MEDIATOR_EMAIL=

# Téléphone du médiateur
MEDIATOR_PHONE=

# -----------------------------------------------------------------------------
# SÉCURITÉ - SIGNATURE DES CERTIFICATS (CRITIQUE)
# -----------------------------------------------------------------------------

# Secret de signature actuel (générer avec: openssl rand -base64 32)
# ⚠️ CHANGER EN PRODUCTION - NE JAMAIS COMMITER
CERT_SIGNING_SECRET=CHANGE-ME-IN-PRODUCTION-USE-openssl-rand-base64-32

# Secret de signature précédent (pour rotation des secrets)
# Permet de valider les anciens certificats pendant la transition
CERT_SIGNING_SECRET_OLD=

# Algorithme de signature (ne pas modifier sauf si vous savez ce que vous faites)
CERT_SIGNING_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# RGPD - DURÉES DE CONSERVATION (EN MOIS)
# -----------------------------------------------------------------------------

# Historique des analyses (défaut: 12 mois)
RETENTION_ANALYSIS_HISTORY=12

# Certificats générés (défaut: 36 mois)
RETENTION_CERTIFICATES=36

# Logs d'audit (défaut: 24 mois)
RETENTION_AUDIT_LOGS=24

# Comptes utilisateurs inactifs (défaut: 36 mois après dernière activité)
RETENTION_USER_ACCOUNTS=36

# Données de paiement (défaut: 120 mois - obligations légales comptables)
RETENTION_PAYMENT_DATA=120

# Images analysées (défaut: suppression immédiate, max 24h)
RETENTION_IMAGES_HOURS=24

# Logs de connexion (défaut: 12 mois)
RETENTION_CONNECTION_LOGS=12

# -----------------------------------------------------------------------------
# CONFORMITÉ RGPD - BASES LÉGALES
# -----------------------------------------------------------------------------

# Base légale par défaut pour les analyses
# Options: contract, legitimate_interest, consent, legal_obligation
RGPD_ANALYSIS_LEGAL_BASIS=contract

# Base légale pour le marketing (si activé)
RGPD_MARKETING_LEGAL_BASIS=consent

# Base légale pour les cookies analytiques
RGPD_ANALYTICS_LEGAL_BASIS=consent

# -----------------------------------------------------------------------------
# LANGUE PAR DÉFAUT
# -----------------------------------------------------------------------------

# Langue par défaut des documents juridiques (fr, en)
DEFAULT_LEGAL_LANGUAGE=fr

# -----------------------------------------------------------------------------
# URLS ET DOMAINES
# -----------------------------------------------------------------------------

# URL principale du site
SITE_URL=https://faketect.com

# URL de l'API
API_URL=https://api.faketect.com

# URL de vérification des certificats
CERTIFICATE_VERIFY_URL=https://faketect.com/verify

# -----------------------------------------------------------------------------
# FEATURES - ACTIVATION DES FONCTIONNALITÉS
# -----------------------------------------------------------------------------

# Activer la génération de certificats juridiques
ENABLE_LEGAL_CERTIFICATES=true

# Activer la chaîne de traçabilité (Chain of Custody)
ENABLE_CHAIN_OF_CUSTODY=true

# Activer les notices RGPD dans les certificats
ENABLE_RGPD_NOTICES=true

# Activer les logs d'audit
ENABLE_AUDIT_LOGS=true

# Activer les cookies analytiques (nécessite consentement)
ENABLE_ANALYTICS_COOKIES=false

# -----------------------------------------------------------------------------
# STANDARDS ET CONFORMITÉ
# -----------------------------------------------------------------------------

# Standard de certification (ne pas modifier)
CERTIFICATION_STANDARD=ISO/IEC 27001

# Version du format de certificat
CERTIFICATE_VERSION=1

# Générateur de certificat
CERTIFICATE_GENERATOR=FakeTect Legal Service v1.0

# -----------------------------------------------------------------------------
# NOTIFICATIONS ET ALERTES
# -----------------------------------------------------------------------------

# Email pour les alertes de sécurité
SECURITY_ALERT_EMAIL=security@faketect.com

# Email pour les alertes RGPD (violations de données)
RGPD_ALERT_EMAIL=dpo@faketect.com

# Email pour les alertes système
SYSTEM_ALERT_EMAIL=admin@faketect.com

# -----------------------------------------------------------------------------
# ENVIRONNEMENT
# -----------------------------------------------------------------------------

# Environnement (development, staging, production)
NODE_ENV=production

# Mode debug pour le système juridique (true/false)
LEGAL_DEBUG_MODE=false

# -----------------------------------------------------------------------------
# NOTES IMPORTANTES
# -----------------------------------------------------------------------------

# ⚠️ AVANT LA MISE EN PRODUCTION:
# 1. Compléter TOUTES les informations entreprise depuis votre KBIS
# 2. Générer un CERT_SIGNING_SECRET fort avec: openssl rand -base64 32
# 3. Créer tous les emails professionnels listés ci-dessus
# 4. Choisir et configurer un médiateur de la consommation
# 5. Souscrire une assurance RC Professionnelle
# 6. Faire valider les documents juridiques par un avocat
# 7. Tester la génération de certificats
# 8. Vérifier que tous les liens juridiques fonctionnent
# 9. Configurer les logs d'audit
# 10. Former l'équipe aux obligations RGPD

# ⚠️ SÉCURITÉ:
# - Ne JAMAIS commiter ce fichier avec les vraies valeurs dans Git
# - Ajouter .env à .gitignore
# - Utiliser un gestionnaire de secrets en production (AWS Secrets Manager, etc.)
# - Changer CERT_SIGNING_SECRET tous les 6 mois
# - Conserver CERT_SIGNING_SECRET_OLD pendant 36 mois (durée validité certificats)

# ⚠️ RGPD:
# - Respecter scrupuleusement les durées de conservation
# - Répondre aux demandes RGPD sous 1 mois maximum
# - Notifier les violations de données sous 72h à la CNIL
# - Tenir un registre des traitements à jour
# - Former régulièrement l'équipe

# 📚 DOCUMENTATION:
# - README complet: docs/legal/README.md
# - Instructions: docs/legal/INSTRUCTIONS-FINALISATION.md
# - Récapitulatif: docs/legal/RECAPITULATIF.md

# 📞 AIDE:
# - CNIL: https://www.cnil.fr
# - Service Public: https://www.service-public.fr
# - Consultation avocat recommandée

# =============================================================================
# FIN DE LA CONFIGURATION
# =============================================================================
